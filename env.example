# Copy this file to `.env` and fill in your credentials.

# Model used for the chat Recipe Bot
MODEL_NAME=openai/gpt-4.1-mini

# Model used for the LLM judge (use a cheaper model for judge evaluation)
MODEL_NAME_JUDGE=openai/gpt-4.1-nano

# Example API keys
# OPENAI_API_KEY=
# TOGETHER_API_KEY=
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Intuit llm-execution-svc (DIRECT) configuration
# Enable this to bypass LiteLLM and call llm-exec directly from the backend.
# -----------------------------------------------------------------------------

# Set to `true` to enable direct calls
LLM_EXEC_ENABLED=false

# Base URL for your target environment (e.g., prf/qal/e2e)
# Example: https://llmexecution-prf.api.intuit.com
LLM_EXEC_BASE_URL=

# Model path segment used by llm-exec v3 endpoints (from API Explorer)
# Example: gpt-4o-2024-05-13-ck
LLM_EXEC_MODEL_PATH=

# Option A (recommended): Single-paste PrivateAuth+ header string
# Paste EXACTLY what works in curl (without the leading 'Authorization: ')
# Example:
# INTUIT_PRIVATEAUTH_HEADER=Intuit_IAM_Authentication intuit_appid="Intuit.learning.learnexp.llmcallsvc", intuit_app_secret="xxxx", intuit_token_type=IAM-Ticket, intuit_token="V1-...", intuit_userid="46210..."
INTUIT_PRIVATEAUTH_HEADER=

# Option B: Individual fields (used only if INTUIT_PRIVATEAUTH_HEADER is empty)
INTUIT_APP_ID=
INTUIT_APP_SECRET=
INTUIT_TOKEN_TYPE=IAM-Ticket
INTUIT_USER_ID=
INTUIT_TOKEN=

# v3 required headers
INTUIT_EXPERIENCE_ID=
INTUIT_ORIGINATING_ASSETALIAS=

# Optional test header (use "true" in preprod if required)
INTUIT_TEST_HEADER=